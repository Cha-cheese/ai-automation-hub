# Local demo mode: works without real Gmail, Slack, Calendar, Tavily, or Gemini keys.
DEMO_MODE=true
APP_ENV=local
SECRET_KEY=local-demo-secret

# Optional: add these later when you want real AI/search.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
TAVILY_API_KEY=

# Optional real integrations.
GOOGLE_SERVICE_ACCOUNT_JSON={}
GMAIL_IMAP_EMAIL=
GMAIL_IMAP_APP_PASSWORD=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#general
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

REQUEST_TIMEOUT_SECONDS=45
LLM_TIMEOUT_SECONDS=20
TAVILY_TIMEOUT_SECONDS=12
